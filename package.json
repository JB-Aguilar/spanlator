{
  "name": "spanlator",
  "version": "0.0.2",
  "description": "Game file translator — Google Translate + glossary",
  "main": "electron/main.js",
  "scripts": {
    "dev:frontend": "cd frontend && npx vite --port 5173",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"node -e setTimeout(() => process.exit(0), 3000) && npm run dev:electron\"",
    "build:frontend": "cd frontend && npx vite build",
    "dist": "npm run build:frontend && npx electron-builder --win --x64",
    "dist:portable": "npm run build:frontend && npx electron-builder --win portable",
    "postinstall": "cd frontend && npm install"
  },
  "build": {
    "appId": "com.spanlator.app",
    "productName": "SpanLator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "icon": "resources/icon.png",
      "certificateSubjectName": null,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SpanLator",
      "uninstallDisplayName": "SpanLator 0.0.2"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "google-translate-api-x": "^10.7.0",
    "multer": "^2.0.0",
    "uuid": "^10.0.0"
  }
}
